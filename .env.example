# Copie para .env e preencha com seus valores

# Banco de dados (SQLite para dev, PostgreSQL para produção)
DATABASE_URL="file:./prisma/dev.db"
# Em produção: DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# NextAuth — gere um segredo com: openssl rand -base64 32
NEXTAUTH_SECRET="substitua-por-uma-string-longa-e-aleatoria"
NEXTAUTH_URL="http://localhost:3000"
# Em produção: NEXTAUTH_URL="https://seudominio.com.br"
